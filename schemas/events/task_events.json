{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "https://multi-agent-platform.com/schemas/events/task_events.json",
  "title": "Task Events Schema",
  "description": "Schema definitions for task lifecycle events",

  "definitions": {
    "base_task_event": {
      "type": "object",
      "required": [
        "event_id",
        "event_type",
        "version",
        "timestamp",
        "source",
        "workflow_id",
        "payload"
      ],
      "properties": {
        "event_id": {
          "type": "string",
          "format": "uuid"
        },
        "event_type": {
          "type": "string"
        },
        "version": {
          "type": "string",
          "pattern": "^\\d+\\.\\d+$"
        },
        "timestamp": {
          "type": "string",
          "format": "date-time"
        },
        "source": {
          "type": "object",
          "required": ["agent_id", "agent_type"],
          "properties": {
            "agent_id": { "type": "string" },
            "agent_type": { "type": "string" },
            "instance_id": { "type": "string" }
          }
        },
        "workflow_id": {
          "type": "string",
          "format": "uuid"
        },
        "correlation_id": {
          "type": "string",
          "format": "uuid"
        },
        "metadata": {
          "type": "object",
          "properties": {
            "priority": {
              "type": "integer",
              "minimum": 1,
              "maximum": 10
            },
            "retry_count": {
              "type": "integer",
              "minimum": 0
            }
          }
        }
      }
    },

    "task_created": {
      "allOf": [
        { "$ref": "#/definitions/base_task_event" },
        {
          "properties": {
            "event_type": { "const": "task.created" },
            "payload": {
              "type": "object",
              "required": ["task_id", "name", "category", "specification"],
              "properties": {
                "task_id": {
                  "type": "string",
                  "format": "uuid"
                },
                "parent_task_id": {
                  "type": "string",
                  "format": "uuid"
                },
                "name": {
                  "type": "string",
                  "maxLength": 500
                },
                "description": {
                  "type": "string"
                },
                "category": {
                  "type": "string",
                  "enum": [
                    "specification",
                    "planning",
                    "backend_coding",
                    "frontend_coding",
                    "devops_coding",
                    "database_coding",
                    "review",
                    "testing",
                    "evaluation",
                    "approval"
                  ]
                },
                "priority": {
                  "type": "integer",
                  "minimum": 1,
                  "maximum": 10,
                  "default": 5
                },
                "specification": {
                  "type": "object",
                  "description": "Task-specific requirements and context"
                },
                "dependencies": {
                  "type": "array",
                  "items": {
                    "type": "string",
                    "format": "uuid"
                  },
                  "description": "IDs of tasks that must complete first"
                },
                "estimated_duration_ms": {
                  "type": "integer",
                  "minimum": 0
                },
                "estimated_cost_usd": {
                  "type": "number",
                  "minimum": 0
                }
              }
            }
          }
        }
      ]
    },

    "task_assigned": {
      "allOf": [
        { "$ref": "#/definitions/base_task_event" },
        {
          "properties": {
            "event_type": { "const": "task.assigned" },
            "payload": {
              "type": "object",
              "required": [
                "task_id",
                "assigned_agent_id",
                "assigned_agent_type"
              ],
              "properties": {
                "task_id": {
                  "type": "string",
                  "format": "uuid"
                },
                "assigned_agent_id": {
                  "type": "string",
                  "description": "ID of the agent assigned to this task"
                },
                "assigned_agent_type": {
                  "type": "string"
                },
                "assigned_at": {
                  "type": "string",
                  "format": "date-time"
                },
                "model_recommendation": {
                  "type": "object",
                  "properties": {
                    "primary_model": { "type": "string" },
                    "fallback_models": {
                      "type": "array",
                      "items": { "type": "string" }
                    }
                  }
                }
              }
            }
          }
        }
      ]
    },

    "task_started": {
      "allOf": [
        { "$ref": "#/definitions/base_task_event" },
        {
          "properties": {
            "event_type": { "const": "task.started" },
            "payload": {
              "type": "object",
              "required": ["task_id", "agent_id", "started_at"],
              "properties": {
                "task_id": {
                  "type": "string",
                  "format": "uuid"
                },
                "agent_id": {
                  "type": "string"
                },
                "started_at": {
                  "type": "string",
                  "format": "date-time"
                },
                "execution_context": {
                  "type": "object",
                  "properties": {
                    "sandbox_id": { "type": "string" },
                    "workspace_path": { "type": "string" },
                    "environment": { "type": "object" }
                  }
                }
              }
            }
          }
        }
      ]
    },

    "task_completed": {
      "allOf": [
        { "$ref": "#/definitions/base_task_event" },
        {
          "properties": {
            "event_type": { "const": "task.completed" },
            "payload": {
              "type": "object",
              "required": [
                "task_id",
                "status",
                "started_at",
                "completed_at",
                "duration_ms"
              ],
              "properties": {
                "task_id": {
                  "type": "string",
                  "format": "uuid"
                },
                "status": {
                  "const": "completed"
                },
                "started_at": {
                  "type": "string",
                  "format": "date-time"
                },
                "completed_at": {
                  "type": "string",
                  "format": "date-time"
                },
                "duration_ms": {
                  "type": "integer",
                  "minimum": 0
                },
                "output": {
                  "type": "object",
                  "description": "Task output data"
                },
                "artifacts": {
                  "type": "array",
                  "items": {
                    "type": "object",
                    "properties": {
                      "type": {
                        "type": "string",
                        "enum": [
                          "file",
                          "code",
                          "document",
                          "report",
                          "image",
                          "other"
                        ]
                      },
                      "path": { "type": "string" },
                      "url": { "type": "string", "format": "uri" },
                      "checksum": { "type": "string" },
                      "size_bytes": { "type": "integer" }
                    }
                  }
                },
                "metrics": {
                  "type": "object",
                  "properties": {
                    "cost_usd": {
                      "type": "number",
                      "minimum": 0
                    },
                    "tokens_used": {
                      "type": "integer",
                      "minimum": 0
                    },
                    "model_used": {
                      "type": "string"
                    },
                    "lines_of_code": {
                      "type": "integer"
                    },
                    "files_created": {
                      "type": "integer"
                    },
                    "files_modified": {
                      "type": "integer"
                    }
                  }
                }
              }
            }
          }
        }
      ]
    },

    "task_failed": {
      "allOf": [
        { "$ref": "#/definitions/base_task_event" },
        {
          "properties": {
            "event_type": { "const": "task.failed" },
            "payload": {
              "type": "object",
              "required": ["task_id", "status", "error", "failed_at"],
              "properties": {
                "task_id": {
                  "type": "string",
                  "format": "uuid"
                },
                "status": {
                  "const": "failed"
                },
                "error": {
                  "type": "object",
                  "required": ["code", "message"],
                  "properties": {
                    "code": { "type": "string" },
                    "message": { "type": "string" },
                    "details": { "type": "object" },
                    "stack_trace": { "type": "string" },
                    "recoverable": { "type": "boolean" }
                  }
                },
                "started_at": {
                  "type": "string",
                  "format": "date-time"
                },
                "failed_at": {
                  "type": "string",
                  "format": "date-time"
                },
                "retry_count": {
                  "type": "integer",
                  "minimum": 0
                },
                "max_retries": {
                  "type": "integer",
                  "minimum": 0
                },
                "will_retry": {
                  "type": "boolean"
                },
                "next_retry_at": {
                  "type": "string",
                  "format": "date-time"
                }
              }
            }
          }
        }
      ]
    },

    "task_retrying": {
      "allOf": [
        { "$ref": "#/definitions/base_task_event" },
        {
          "properties": {
            "event_type": { "const": "task.retrying" },
            "payload": {
              "type": "object",
              "required": ["task_id", "retry_count", "retry_reason"],
              "properties": {
                "task_id": {
                  "type": "string",
                  "format": "uuid"
                },
                "retry_count": {
                  "type": "integer",
                  "minimum": 1
                },
                "max_retries": {
                  "type": "integer"
                },
                "retry_reason": {
                  "type": "string"
                },
                "previous_error": {
                  "type": "object"
                },
                "retry_delay_ms": {
                  "type": "integer"
                },
                "retry_at": {
                  "type": "string",
                  "format": "date-time"
                }
              }
            }
          }
        }
      ]
    },

    "task_cancelled": {
      "allOf": [
        { "$ref": "#/definitions/base_task_event" },
        {
          "properties": {
            "event_type": { "const": "task.cancelled" },
            "payload": {
              "type": "object",
              "required": ["task_id", "status", "cancelled_by", "reason"],
              "properties": {
                "task_id": {
                  "type": "string",
                  "format": "uuid"
                },
                "status": {
                  "const": "cancelled"
                },
                "cancelled_by": {
                  "type": "string"
                },
                "reason": {
                  "type": "string"
                },
                "cancelled_at": {
                  "type": "string",
                  "format": "date-time"
                }
              }
            }
          }
        }
      ]
    }
  },

  "oneOf": [
    { "$ref": "#/definitions/task_created" },
    { "$ref": "#/definitions/task_assigned" },
    { "$ref": "#/definitions/task_started" },
    { "$ref": "#/definitions/task_completed" },
    { "$ref": "#/definitions/task_failed" },
    { "$ref": "#/definitions/task_retrying" },
    { "$ref": "#/definitions/task_cancelled" }
  ]
}
